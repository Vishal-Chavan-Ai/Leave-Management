{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug CAP",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npx",
      "args": [
        "cds",
        "run"
      ],
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "env": {
        "NODE_ENV": "development",
        "DEBUG": "cds:*"
      }
    }
  ]
}